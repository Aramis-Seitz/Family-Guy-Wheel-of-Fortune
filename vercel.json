{
  "version": 2,
  "buildCommand": "npm run build",
  "outputDirectory": "public/dist",
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/index" },
    { "source": "/", "destination": "/api/index" },
    { "source": "/login.html", "destination": "/api/index" },
    { "source": "/main.html", "destination": "/api/index" },
    { "source": "/signup.html", "destination": "/api/index" }
  ]
}
