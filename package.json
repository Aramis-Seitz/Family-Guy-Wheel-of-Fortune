{
  "name": "fullstack-project",
  "private": true,
  "workspaces": [
    "public",
    "server"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev --workspace server\" \"npm run build --workspace public\"",
    "build": "npm run build --workspace server && npm run build --workspace public",
    "test": "npm run test --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "concurrently": "^8.0.0",
    "vitest": "^4.1.8"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.104.0",
    "dotenv": "^17.4.2"
  }
}
