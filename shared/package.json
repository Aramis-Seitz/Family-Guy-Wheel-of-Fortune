{
  "name": "shared",
  "version": "1.0.0",
  "type": "module",
  "main": "dist-cjs/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist-cjs/index.d.ts",
        "default": "./dist-cjs/index.js"
      }
    }
  },
  "scripts": {
    "build": "tsc && tsc --project tsconfig.cjs.json && node scripts/write-cjs-package.mjs",
    "dev": "tsc --watch --preserveWatchOutput",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "typescript": "^5.9.3"
  }
}